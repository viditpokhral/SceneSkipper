{
  "name": "sceneskip-extension",
  "version": "1.0.0",
  "description": "SceneSkip Extension — crowdsourced scene skipping for any video",
  "scripts": {
    "build": "npm run build:chrome && npm run build:firefox",
    "build:chrome": "NODE_ENV=production TARGET=chrome webpack --mode production",
    "build:firefox": "NODE_ENV=production TARGET=firefox webpack --mode production",
    "dev": "npm run dev:chrome",
    "dev:chrome": "NODE_ENV=development TARGET=chrome webpack --mode development --watch",
    "dev:firefox": "NODE_ENV=development TARGET=firefox webpack --mode development --watch"
  },
  "devDependencies": {
    "@types/chrome": "^0.0.268",
    "copy-webpack-plugin": "^14.0.0",
    "ts-loader": "^9.5.1",
    "typescript": "^5.3.3",
    "webpack": "^5.90.0",
    "webpack-cli": "^5.1.4"
  }
}